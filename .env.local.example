# OpenAI API Key (required for creative brief generation and product summarization)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# Pexels API Key (for background video/image search)
# Get yours at: https://www.pexels.com/api/
PEXELS_API_KEY=your-pexels-api-key

# Giphy API Key (for GIF overlay search)
# Get yours at: https://developers.giphy.com/
GIPHY_API_KEY=your-giphy-api-key

# App URL (used for generating video URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000
